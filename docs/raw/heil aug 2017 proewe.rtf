\par \pard\plain \s0\ql\widctlpar\hyphpar0\ltrpar\cf1\kerning1\dbch\af5\langfe1081\dbch\af7\afs24\alang1078\loch\f3\fs24\lang1078\widctlpar\hyphpar0\rtlch \ltrch\loch

