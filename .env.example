# ─────────────────────────────────────────────────────────
# Contact form — set these in Vercel (Production + Preview + Development)
# and in .env.local for local development. Never commit .env.local.
# ─────────────────────────────────────────────────────────

# Where contact-form submissions land.
CONTACT_TO_EMAIL=you@example.com

# "From" address. Must be on a domain verified with Resend.
# For local dev you can use "onboarding@resend.dev" — it only sends to
# the Resend account's own email while you verify a real sender domain.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Resend API key. Create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
